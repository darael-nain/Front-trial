    <!--#4dif vFolioOt#"S/N"-->
        <!--#4dif vNotify = false-->
            <!--#4dif vDisabledCerrado=""-->
            <div id="label-notify" class="msg-status-notify-false">Por Notificar.</div>
            <!--#4dendif-->
        <!--#4delse-->
            <div id="label-notify" class="msg-status-notify-true">Notificada.</div>
        <!--#4dendif-->
        <!--#4DIF ot_validated-->
            <div id="label-notify" class="msg-status-notify-true" style="margin-top: 30px;">Validada.</div>
        <!--#4DELSE-->
            <div id="label-notify" class="msg-status-notify-false" style="margin-top: 30px; margin-left: -60px;">Por validar.</div>
        <!--#4DENDIF-->
    <!--#4dendif-->

    <div class="folio-ot"><!--#4DVAR vFolioOt--></div>
    <div class="stateot <!--#4DVAR vStyleStateOt-->">
        <!--#4dif vFolioOt#"S/N"-->
            <span><!--#4DVAR vEstadoOT_--></span>
        <!--#4dendif-->
    </div>

    <!--#4DIF vEstadoOT_="CERRADA"-->
    <div style="text-align:right;margin-bottom:10px">
        <label class="color-blue" for="referencia-ot">Por </label>
        <span class="color-blue"><!--#4DVAR vNombreCerrador--></span>
        <label class="color-blue" for="referencia-ot">El </label>
        <span class="color-blue"><!--#4DVAR vFechaCierre--></span>
        <label class="color-blue" for="referencia-ot">A las </label>
        <span class="color-blue"><!--#4DVAR vHoraCierre--> Hrs.</span>
        <br>
        <label class="color-blue" for="referencia-ot">Observación:</label>
        <span class="color-blue"><!--#4DHTMLVAR vMensajeCierre--></span>
    </div>
    <!--#4dendif-->

    <article id="scrollval" style="margin-top: 10px; margin-bottom: 10px; text-align: left;">
        <h1 style="font-weight: bold; font-size: 16px; text-align: left; text-indent: 40px; padding-top: 10px; padding-bottom: 5px; display: inline-block; vertical-align: top;">Validaciones</h1>
        <header class="header-v3" style="display: inline-block; width: auto; vertical-align: top; padding-top: 10px; zoom: .8;">
            <nav class="toolbox" id="menu">
                <ul style="height: auto !important;"></ul>
            </nav>
        </header>
        <h2 style="display: none;"><strong>Estado</strong> <span></span> <span></span></h2>
        <ul class="steps"></ul>
    </article>

    <!--#4dif vFolioOt#"S/N"-->
        <!--#4DIF vCodTipoOt="PROYECTO2"-->
            <div class="box-top">
                <label class="label-1" for="referencia-ot">Del Proyecto : </label>
                <span style="text-transform:uppercase!important;font-size:15px"><!--#4DVAR vRefProyNeg--></span>
            </div>
        <!--#4dendif-->
        <!--#4DIF vCodTipoOt="PROYECTO"-->
            <div class="box-top">
                <label class="label-1" for="referencia-ot">Del Negocio : </label>
                <span style="text-transform:uppercase!important;font-size:15px;vertical-align:middle"><!--#4DVAR vRefProyNeg--></span>
            </div>
        <!--#4dendif-->

        <div class="box-top">
            <span class="fancy-text-content">Creada por <!--#4DTEXT vNombreEmisor--> el <!--#4DTEXT vFechaEmision--> a las <!--#4DTEXT vHoraEmision--> Hrs.</span>
    <!--#4dendif-->

        <script>

        $(document).ready(function(){

            var divModulo = $('div.moduloOrigen');
            var moduloOt = "<!--#4DHTML moduloOt-->";
            var id_proyecto = "<!--#4DHTML id_proyecto-->";
            var folio_proyecto = "<!--#4DHTML folio_proyecto-->";
            var referencia_proyecto = "<!--#4DHTML referencia_proyecto-->";
            divModulo.find('p')[0].innerHTML = moduloOt + ' ' + folio_proyecto;
            divModulo.find('p')[0].title = referencia_proyecto;
            if( moduloOt != ""){
                divModulo.css('display','inline-block');
            }
            divModulo.on('click', 'p', function(){
                if(moduloOt = "PROYECTO"){
                    window.open("http://" + window.location.host + "/4DACTION/wbienvenidos#/proyectos/content.shtml?id="+ id_proyecto , '_blank'); 
                }
            });


        });
        </script>
        <div class="moduloOrigen" style="display: none">
            <label>Módulo origen</label>
            <p></p>
        </div>

    <div class="box-top">
        <label class="label-1" for="referencia-ot">Referencia</label>
        <!--#4DIF (aCheckPermiso{18}) | (vLogin=vLoginResp_creado)-->
            <input required autocomplete="off" class="input-1 guardar-express-ot req" id="referencia-ot" name="referenciaot" type="text" value="<!--#4dvar vReferencia-->" <!--#4DVAR vDisabledCerrado--> />
        <!--#4delse-->
            <input required disabled autocomplete="off" class="input-1 guardar-express-ot req" id="referencia-ot" name="referenciaot" type="text" value="<!--#4dvar vReferencia-->" />
        <!--#4dendif-->
        <span class="obligatorio">*</span>
    </div>

    <div class="box-left">

        <div class="box-tipoot">
            <label class="label-1" for="referencia-ot">Tipo OT</label>
            <!--#4dif (aCheckPermiso{18}=true) | (vLogin=vLoginResp_creado)-->
                <!--#4dif vCodTipoOt="PROYECTO2"-->
                    <select disabled class="select-1 guardar-express-ot" id="tipo-ot" name="tipoot">
                <!--#4delse-->
                    <select class="select-1 guardar-express-ot" id="tipo-ot" name="tipoot" <!--#4DVAR vDisabledCerrado-->>
                <!--#4dendif-->
                    <option selected="selected" value="<!--#4dvar vCodTipoOt-->"><!--#4dvar vDesTipoOt--></option>
                    <!--#4dloop a_TipoOt-->
                        <!--#4dif a_TipoOt{a_TipoOt}#vCodTipoOt-->
                            <!--#4dif a_TipoOt{a_TipoOt}="PROYECTO"-->
                                <option value="<!--#4dvar a_TipoOt{a_TipoOt}-->"><!--#4dvar a_TipoOt{a_TipoOt}--></option>
                            <!--#4delse-->
                                <option value="<!--#4dvar a_TipoOt{a_TipoOt}-->"><!--#4dvar a_TipoOt{a_TipoOt}--></option>
                            <!--#4dendif-->
                        <!--#4dendif-->
                    <!--#4dendloop-->
                </select>
            <!--#4delse-->
                <select disabled class="select-1 guardar-express-ot" id="tipo-ot" name="tipoot">
                    <option selected="selected" value="<!--#4dvar vCodTipoOt-->"><!--#4dvar vDesTipoOt--></option>
                    <!--#4dloop a_TipoOt-->
                        <!--#4dif a_TipoOt{a_TipoOt}#vCodTipoOt-->
                             <!--#4dif a_TipoOt{a_TipoOt}="PROYECTO"-->
                                <option value="<!--#4dvar a_TipoOt{a_TipoOt}-->"><!--#4dvar a_TipoOt{a_TipoOt}--></option>
                            <!--#4delse-->
                                <option value="<!--#4dvar a_TipoOt{a_TipoOt}-->"><!--#4dvar a_TipoOt{a_TipoOt}--></option>
                            <!--#4dendif-->
                        <!--#4dendif-->
                    <!--#4dendloop-->
                </select>
            <!--#4dendif-->
        </div>



        <div class="buscador-de-proyectos">
            <div class="box-busca-proy">

                <!--#4dif vCodTipoOt="PROYECTO"-->
                     <label class="label-1" for="referencia-ot">Negocio</label>
                <!--#4dendif-->
                <!--#4dif vCodTipoOt="PROYECTO2"-->
                     <label class="label-1" for="referencia-ot">Proyecto</label>
                <!--#4dendif-->
                <!--#4dif vCodTipoOt="GENERAL"-->
                     <label class="label-1" for="referencia-ot">Proyecto</label>
                <!--#4dendif-->

                <input id="idproyecto-select" name="idnvproyecto" type="hidden" value="<!--#4dvar vIdNvProyecto-->" />

                <div style="display:inline-block">
                <!--#4dif (aCheckPermiso{18}=true) | (vLogin=vLoginResp_creado)-->
                    <input required class="buscadores guardar-express-ot req" id="buscar-proyectos-auto" name="buscar-empresa" placeholder="buscar por referencia, razon" value="<!--#4dvar vRefProyecto-->" type="text" <!--#4DVAR vDisabledCerrado--> />
                <!--#4delse-->
                    <input required class="buscadores guardar-express-ot req" disabled id="buscar-proyectos-auto" name="buscar-empresa" placeholder="buscar por referencia, razon" value="<!--#4dvar vRefProyecto-->" type="text"/>
                <!--#4dendif-->
                </div>
                <span class="obligatorio">*</span>
            </div>

            <div class="items-p-ot">
                <label class="label-1" for="referencia-ot">Origen</label>
                <!--#4dif (aCheckPermiso{18}=true) | (vLogin=vLoginResp_creado)-->
                    <select id="items-tipo-ot" name="items-tipo-ot" class="guardar-express-ot req" <!--#4DVAR vDisabledCerrado-->>
                        <option selected="selected" value="<!--#4dvar vTipoItemsIdSelect-->">
                            <!--#4dvar vTipoItemsDesSelect-->
                        </option>
                        <!--#4dif vTipoItemsIdSelect#"ITEM DIRECTO"-->
                         <option value="ITEM DIRECTO">ITEM DIRECTO</option>
                        <!--#4dendif-->
                        <!--#4dif vTipoItemsIdSelect#"OTROS GASTOS"-->
                        <option value="OTROS GASTOS">OTROS GASTOS</option>
                        <!--#4dendif-->
                    </select>
                <!--#4delse-->
                    <select disabled id="items-tipo-ot" name="items-tipo-ot" class="guardar-express-ot req">
                        <option selected="selected" value="<!--#4dvar vTipoItemsIdSelect-->">
                            <!--#4dvar vTipoItemsDesSelect-->
                        </option>
                        <!--#4dif vTipoItemsIdSelect#"ITEM DIRECTO"-->
                         <option value="ITEM DIRECTO">ITEM DIRECTO</option>
                        <!--#4dendif-->
                        <!--#4dif vTipoItemsIdSelect#"OTROS GASTOS"-->
                        <option value="OTROS GASTOS">OTROS GASTOS</option>
                        <!--#4dendif-->
                    </select>
                <!--#4dendif-->
            </div>
            <div class="itemsnv">
                <!--#4dif (aCheckPermiso{18}=true) | (vLogin=vLoginResp_creado)-->
                    <select class="combos-normal guardar-express-ot req" id="llave-det-nvx" name="llave-det-nvx" <!--#4DVAR vDisabledCerrado-->>       <!--#4dif Not(Undefined(vLista))-->
                            <!--#4dvar vLista-->
                        <!--4dendif-->
                    </select>
                <!--#4delse-->
                    <select disabled class="combos-normal guardar-express-ot req" id="llave-det-nvx" name="llave-det-nvx">
                        <!--#4dif Not(Undefined(vLista))-->
                            <!--#4dvar vLista-->
                        <!--4dendif-->
                    </select>
                <!--#4dendif-->
            </div>
        </div>

        <div class="buscador-de-empresas">
           <div class="box-busca-emp">
                <label class="label-1" for="referencia-ot">Empresa</label>
                <input id="idempresa-select" name="idempresa" type="hidden" value="<!--#4dvar vIdEmp-->"/>
                <div style="display:inline-block">
                    <!--#4dif (aCheckPermiso{18}=true) | (vLogin=vLoginResp_creado)-->
                        <!--#4dif vCodTipoOt="PROYECTO2"-->
                             <input required class="buscadores guardar-express-ot req" disabled id="buscar-empresas-auto" name="buscar-empresa" placeholder="buscar por razon, rut, email" value="<!--#4dvar vNombreEmp-->" type="text"/>
                        <!--#4delse-->
                            <input required class="buscadores guardar-express-ot req" id="buscar-empresas-auto" name="buscar-empresa" placeholder="buscar por razon, rut, email" value="<!--#4dvar vNombreEmp-->" type="text" <!--#4DVAR vDisabledCerrado--> />
                        <!--#4dendif-->
                    <!--#4delse-->
                         <input required class="buscadores guardar-express-ot req" disabled id="buscar-empresas-auto" name="buscar-empresa" placeholder="buscar por razon, rut, email" value="<!--#4dvar vNombreEmp-->" type="text"/>
                    <!--#4dendif-->
                </div>
                 <span class="obligatorio">*</span>
            </div>
        </div>

         <div class="box-motivo">
            <label class="label-1">Motivo</label>
            <select required="" id="motivo" name="motivo" class="guardar-express-ot req">
                <option <!--#4DIF (vMotivo="") & (vIdMotivo=0)-->selected="selected" <!--#4DENDIF-->value="0">SELECCIONAR</option>
                <!--#4DLOOP aMotivoIds-->
                <option value="<!--#4DVAR aMotivoIds{aMotivoIds}-->"<!--#4DIF (vIdMotivo=aMotivoIds{aMotivoIds})--> selected="selected"<!--#4DENDIF-->><!--#4DTEXT Uppercase(aMotivoNombres{aMotivoIds};*)--></option>
                <!--#4DENDLOOP-->
            </select>
        </div>

        <div class="dates-and-times">
            <div>
                <label class="label-1 show-hide-horas">Fecha inicio</label>
                <input  <!--#4DIF Not(_V3_verifica_permisos_web(vLogin;611))-->disabled<!--#4DENDIF--> name="fecha_comienzo" class="datepicker guardar-express-ot req" type="text" value="<!--#4DTEXT string(vFechaComienzo;1)-->"/>

                <label class="label-1 show-hide-horas">Hora inicio</label>
                <input <!--#4DIF Not(_V3_verifica_permisos_web(vLogin;611))-->disabled<!--#4DENDIF--> name="hora_comienzo" class="guardar-express-ot req" value="<!--#4DTEXT vHoraComienzo-->" type="time" step="1">
            </div>

             <div>
                <label class="label-1 show-hide-horas">Fecha termino</label>
                <input name="fechavcto" class="datepicker guardar-express-ot req" type="text" value="<!--#4dvar string(vFechaVcto;1)-->" <!--#4DVAR vDisabledCerrado--> />
                <label class="label-1 show-hide-horas">Hora termino</label>
                <input name="hora" class="guardar-express-ot req" value="<!--#4DTEXT vHoraDes-->" type="time" step="1" <!--#4DVAR vDisabledCerrado-->>
            </div>

            <!--#4DIF _V3_verifica_permisos_web(vLogin;610)-->
            <div>
                <label class="label-1 show-hide-horas">Fecha final (Cliente)</label>
                <input name="fecha_final" class="datepicker guardar-express-ot req" type="text" value="<!--#4DTEXT string(vFechaFinal;1)-->"/>

                <label class="label-1 show-hide-horas">Hora final</label>
                <input name="hora_final" class="guardar-express-ot req" value="<!--#4DTEXT vHoraFinal-->" type="time" step="1">
                <label></label>
            </div>
            <!--#4DENDIF-->
        </div>

    </div>

    <div class="box-right">
        <div class="box-importancia">
            <label class="label-1">Importancia</label>
            <!--#4dif (_V3_verifica_permisos_web(vLogin;18)) | (vLogin=vLoginResp_creado)-->
                <select required id="importancia" name="importancia" class="guardar-express-ot req" <!--#4DVAR vDisabledCerrado-->>
                    <option selected="selected" value="<!--#4dvar vIdPrioridad-->"><!--#4dvar vDesPrioridad--></option>
                    <!--#4dloop aPrio-->
                        <!--#4dif aPrio{aPrio}#vIdPrioridad-->
                        <option value="<!--#4dvar aPrio{aPrio}-->"><!--#4dvar aPrio{aPrio}--></option>
                        <!--#4dendif-->
                    <!--#4dendloop-->
                </select>
            <!--#4delse-->
                <select required disabled id="importancia" name="importancia" class="guardar-express-ot req" >
                    <option selected="selected" value="<!--#4dvar vIdPrioridad-->"><!--#4dvar vDesPrioridad--></option>
                    <!--#4dloop aPrio-->
                        <!--#4dif aPrio{aPrio}#vIdPrioridad-->
                        <option value="<!--#4dvar aPrio{aPrio}-->"><!--#4dvar aPrio{aPrio}--></option>
                        <!--#4dendif-->
