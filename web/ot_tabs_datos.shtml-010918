
<div id="dialog-send-file" style="display: none;">
    <label>
        <span>Email</span>
        <input type="email" name="email">
    </label>
</div>
<div id="tab-1-datos-ot">

    <!--
    <div class="validation-section">
        <div class="text">OT PENDIENTES POR VALIDAR - EXCEDE HORAS PRESUPUESTADAS</div>
        <div class="text-validador">Responsable de validar: Ricardo Cañas</div>
