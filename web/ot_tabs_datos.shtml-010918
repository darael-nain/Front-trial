            <!--#4dif (_V3_verifica_permisos_web(vLogin;18)) | (vLogin=vLoginResp_creado)-->
                <select required class="guardar-express-ot req" id="area-trabajo" name="areatrabajo" onChange="fn_load_user(this.value)" <!--#4DVAR vDisabledCerrado-->>
                    <option selected="selected" value="<!--#4dvar vIdArea-->"><!--#4dvar vDesArea--></option>
                    <!--#4dloop aAreaId-->
                        <!--#4dif aAreaId{aAreaId}#vIdArea-->
                        <option value="<!--#4dvar aAreaId{aAreaId}-->"><!--#4dvar aAreaNombre{aAreaId}--></option>
                        <!--#4dendif-->
                    <!--#4dendloop-->
                </select>
            <!--#4delse-->
                <select required class="guardar-express-ot req" disabled id="area-trabajo" name="areatrabajo" onChange="fn_load_user(this.value)" >
                    <option selected="selected" value="<!--#4dvar vIdArea-->"><!--#4dvar vDesArea--></option>
                    <!--#4dloop aAreaId-->
                        <!--#4dif aAreaId{aAreaId}#vIdArea-->
                        <option value="<!--#4dvar aAreaId{aAreaId}-->"><!--#4dvar aAreaNombre{aAreaId}--></option>
                        <!--#4dendif-->
                    <!--#4dendloop-->
                </select>
            <!--#4dendif-->
            <span class="obligatorio">*</span>
        </div>

        <div class="box-responsable">
            <label class="label-1">Responsable</label>
            <!--#4dif (_V3_verifica_permisos_web(vLogin;18)) | (vLogin=vLoginResp_creado)-->
                <select required class="guardar-express-ot req" id="responsables-area" name="responsables-area" onChange="guarda_responsable(this.value)" <!--#4DVAR vDisabledCerrado-->>
                    <option selected="selected" value="<!--#4dvar vLoginResp-->"><!--#4dvar vNomResp--></option>
                    <!--#4dif(Not(Undefined(aLoginAreaResp)))-->
                        <!--#4dloop aLoginAreaResp-->
                            <!--#4dif aLoginAreaResp{aLoginAreaResp}#vLoginResp-->
                            <option value="<!--#4dvar aLoginAreaResp{aLoginAreaResp}-->">
                                <!--#4dvar aNombresAreaResp{aLoginAreaResp}-->
                            </option>
                            <!--#4dendif-->
                        <!--#4dendloop-->
                    <!--#4dendif-->
                </select>
            <!--#4delse-->
                <select required class="guardar-express-ot req" readonly id="responsables-area" name="responsables-area" onChange="guarda_responsable(this.value)">
                    <option selected="selected" value="<!--#4dvar vLoginResp-->"><!--#4dvar vNomResp--></option>
                    <!--#4dloop aLoginAreaResp-->
                        <!--#4dif aLoginAreaResp{aLoginAreaResp}#vLoginResp-->
                        <option value="<!--#4dvar aLoginAreaResp{aLoginAreaResp}-->">
                            <!--#4dvar aNombresAreaResp{aLoginAreaResp}-->
                        </option>
                        <!--#4dendif-->
                    <!--#4dendloop-->
                </select>
            <!--#4dendif-->
            <span class="obligatorio">*</span>
