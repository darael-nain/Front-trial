            <!--#4DENDIF-->
        <!--#4DENDIF-->


            <label class="label-1">H. Asignadas</label>
        <!--#4dif (_V3_verifica_permisos_web(vLogin;18)) | (vLogin=vLoginResp_creado)-->
            <input required class="hasignada guardar-express-ot" id="hasignada" name="hasignada" type="text" value="<!--#4dvar vHAsiganadas-->" <!--#4DVAR vDisabledCerrado--> />
        <!--#4delse-->
            <input required readonly class="hasignada guardar-express-ot" id="hasignada" name="hasignada" type="text" value="<!--#4dvar vHAsiganadas-->" />
        <!--#4dendif-->

        <!--#4dif vCodTipoOt="PROYECTO"-->

            <!--#4DIF _V3_verifica_permisos_web(vLogin;494)-->

                <label class="label-1 show-hide-horas">Diferencia</label>
                <input class="hasignada2 show-hide-horas" id="hdisp" readonly type="text" value="<!--#4dvar vHDisp-->" />

                <label class="label-1 show-hide-horas">H. Reales</label>
                <input readonly class="hasignada2 show-hide-horas" type="text" value="<!--#4DTEXT  HRealeshh-->"/>

                <label class="label-1 show-hide-horas">Costo. Unit</label>
                <input style="width:100px" readonly class="hasignada2 show-hide-horas" type="text" value="<!--#4DTEXT  String(CostoUnihh;"$ ###.###.###.##0")-->" />

                <label class="label-1 show-hide-horas">Total Real</label>
                <input style="width:100px" readonly class="hasignada2 show-hide-horas" type="text" value="<!--#4DTEXT  String(costoTotalReal;"$ ###.###.###.##0")-->" />

           <!--#4DENDIF-->
           </div>

            <!-- <label class="label-1 show-hide-horas" >Total</label>
            #4dif num(vHDif)<0- ->
            <input class="hasignada2 color-red-normal show-hide-horas" id="htotal" disabled type="text" value="<!- -#4dvar vHTotal- ->" />
            <!- -#4delse- ->
            <input class="hasignada2 show-hide-horas" id="htotal" disabled type="text" value="<!- -#4dvar vHTotal- ->" />
            < !- -#4dendif

            <label class="label-1 show-hide-horas">Restantes</label>
            <input class="hasignada2 show-hide-horas" id="hrest" disabled type="text" value="<! - -#4dvar vHDisp" />   -->
        <!--#4dendif-->

    </div>

    <div class="box-bottom">
        <div>
            <label class="label-1">Descripci&oacute;n</label>
            <!--#4dif (_V3_verifica_permisos_web(vLogin;18)) | (vLogin=vLoginResp_creado)-->
                <textarea required class="guardar-express-ot req" id="idcomment-otxx" name="content" <!--#4DVAR vDisabledCerrado-->><!--#4dvar vMensaje--></textarea>
            <!--#4delse-->
                <textarea required class="guardar-express-ot req" readonly id="idcomment-otxx" name="content"><!--#4dvar vMensaje--></textarea>
            <!--#4dendif-->
            <span class="obligatorio">*</span>

            <!--#4dif vDisabledCerrado=""-->
            <!--<a class="agrandar-text">+</a>-->
            <!--<a style="display:none" class="reducir-text">-</a>-->
            <div style="text-align:left;margin-left:-15px">
                <button title="OT" type="button" id="btn-subir-archivo">Adjuntar archivo</button>
            </div>
            <!--#4dendif-->
        </div>

        <div class="contaianer-todo-file">
            <div class="label-archivos-ot"><label>Archivos : </label><label> Descargar haciendo click en el archivo.</label></div>
            <div class="box-files-ot">
                <!--#4dloop aIdArchivo-->
                    <!--#4dif (aFrom{aIdArchivo}="OT") | (aFrom{aIdArchivo}="COMPONENTE")-->
                    <div id="id<!--#4dvar aIdArchivo{aIdArchivo}-->" class="box-items-files">
                        <!--#4dif aDesFormatoArchivo{aIdArchivo}="IMAGEN"-->
                            <!--#4dif aFrom{aIdArchivo}="OT"-->
                                 <img alt="<!--#4dvar aAncho{aIdArchivo}-->-<!--#4dvar aAlto{aIdArchivo}-->" id="<!--#4dvar aIdArchivo{aIdArchivo}-->" class="img-popup" src="/uploads/<!--#4dvar aIdArchivo{aIdArchivo}-->.<!--#4dvar aFormatoArchivo{aIdArchivo}-->">
                            <!--#4delse-->
                                 <img alt="<!--#4dvar aAncho{aIdArchivo}-->-<!--#4dvar aAlto{aIdArchivo}-->" id="<!--#4dvar aIdArchivo{aIdArchivo}-->" class="img-popup" src="/uploads_componentes_tarea/<!--#4dvar aNombreArchivo{aIdArchivo}-->">
                            <!--#4dendif-->
                        <!--#4delse-->
                            <!--#4dif aDesFormatoArchivo{aIdArchivo}="AUDIO"-->
                                <!--#4dif aFrom{aIdArchivo}="OT"-->
                                    <a target="_black" href="/uploads/<!--#4dvar aIdArchivo{aIdArchivo}-->.<!--#4dvar aFormatoArchivo{aIdArchivo}-->">
                                    <audio controls="controls">
                                        <source src="/uploads/<!--#4dvar aNombreArchivo{aIdArchivo}-->" type="audio/mpeg" />
                                        Tu navegador no soporta el elemento de audio, actualize a uno mas moderno, :)!
                                    </audio>
                                    </a>
                                <!--#4delse-->
                                    <a target="_black" href="/uploads_componentes_tarea/<!--#4dvar aNombreArchivo{aIdArchivo}-->">
                                    <audio controls="controls">
                                        <source src="/uploads_componentes_tarea/<!--#4dvar aNombreArchivo{aIdArchivo}-->" type="audio/mpeg" />
                                        Tu navegador no soporta el elemento de audio, actualice a uno mas moderno, :)!
                                    </audio>
                                </a>
                                <!--#4dendif-->
                            <!--#4delse-->
                                <!--#4dif aFrom{aIdArchivo}="OT"-->
                                    <a target="_black" href="/uploads/<!--#4dvar aIdArchivo{aIdArchivo}-->.<!--#4dvar aFormatoArchivo{aIdArchivo}-->">
                                     <img src="/extensiones/PNG/<!--#4dvar aFormatoArchivo{aIdArchivo}-->.png">
                                    </a>
                                <!--#4delse-->
                                    <a target="_black" href="/uploads_componentes_tarea/<!--#4dvar aNombreArchivo{aIdArchivo}-->">
                                     <img src="/extensiones/PNG/<!--#4dvar aFormatoArchivo{aIdArchivo}-->.png">
                                    </a>
                                <!--#4dendif-->
                            <!--#4dendif-->
                        <!--#4dendif-->
                        <span class="des-file"><!--#4dvar aDesArchivo{aIdArchivo}--></span>

                        <!--#4dif aFrom{aIdArchivo}="COMPONENTE"-->
                            <a rel="<!--#4dvar aIdArchivo{aIdArchivo}-->" class="delete-file-comp" style="cursor:pointer">x</a>
                        <!--#4delse-->
                            <a rel="<!--#4dvar aIdArchivo{aIdArchivo}-->" class="delete-file-normal" style="cursor:pointer">x</a>
                        <!--#4dendif-->
                        <a rel="<!--#4dvar aIdArchivo{aIdArchivo}-->" class="send-file" style="cursor:pointer" title="Enviar archivo por email">@</a>
                    </div>
                    <!--#4dendif-->
                <!--#4dendloop-->
            </div>
        </div>
    </div>

    <div class="box-bottom-2-">


        <div class="box-comment-ot">
            <!--#4dif vFolioOt#"S/N"-->
            <label class="caca">Comentarios : </label><img id="status-save-comment" src='/imagenes_green/ajaxloader.gif'>
            <div>
                <span class="photo-comment"><img src="<!--#4DVAR vFotoLogueado-->"></span>
                <span>
                    <textarea id="text-coment-ot" class="input-coment-det-rev" placeholder="Agregar un comentario..."></textarea>
                </span>
                <button id="btn-comment-ot" type="button">Comentar</button>
            </div>
            <!--4dendif-->
            <div class="list-comment-ot">
                <!--#4dloop aIdComOt-->
                  <div class="items-comentario" id="<!--#4DVAR aIdComOt{aIdComOt}-->">
                    <div>
                        <span class="nro"><!--#4DVAR aNroComOt{aIdComOt}--></span>
                        <span class="photo"><img src="<!--#4DVAR aPhotoRespComOt{aIdComOt}-->"></span>
                        <span class="name">
                            <!--#4DVAR aNomRespComOt{aIdComOt}--> /
                            <span class="especial-span"><!--#4DVAR aEmailRespComOt{aIdComOt}--></span>
                            <!--#4dif aTypeRespComOt{aIdComOt}="guest"-->
                                <span class="guest-tag">( Invitado )</span>
                            <!--#4dendif-->
                        </span>
                    </div>
                    <div>
                        <span class="comment"><!--#4DHTMLVAR aDesComOt{aIdComOt}--></span>
                        <span class="date">
                            Comentado el <!--#4DVAR aDateComOt{aIdComOt}--> a las <!--#4DVAR aTimeComOt{aIdComOt}-->
                        </span>
                    </div>
                  </div>
                <!--#4dendloop-->
            </div>
        </div>
    </div>

    <hr class="linea-ql">


    <p class="set-botones">
        <!--#4dif vDisabledCerrado=""-->
        <button id="saveot-ajax" type="button">Guardar</button>
        <!--#4dendif-->

        <!--#4dif vFolioOt#"S/N"-->
            <!--#4dif vDisabledCerrado=""-->
            <button id="notificar-ot" type="button">Notificar</button>
            <!--#4dendif-->

            <button id="duplicar-ot" type="button">Duplicar</button>

            <!--#4dif vEstadoOT_="ANULADA"-->
                <button id="btn-cancel-ot" class="hide-target" type="button">Anular</button>
                <button id="btn-close-ot" class="hide-target" type="button">Cerrar</button>
            <!--#4dendif-->

            <!--#4dif vEstadoOT_="CERRADA"-->
                <button id="btn-cancel-ot" class="hide-target" type="button">Anular</button>
                <button id="btn-close-ot" class="hide-target" type="button">Cerrar</button>
                <!--#4dif (_V3_verifica_permisos_web(vLogin;21)-->
                <button id="btn-open-ot" class="show-target" type="button">Abrir</button>
                <!--#4dendif-->
            <!--#4dendif-->

            <!--#4dif (vEstadoOT_="PENDIENTE")|(vEstadoOT_="ATRASADA")-->
                <!--#4DIF (_V3_verifica_permisos_web(vLogin;20)-->
                    <button id="btn-cancel-ot" class="show-target" type="button">Anular</button>
                <!--#4DENDIF-->
                <!--#4dif (_V3_verifica_permisos_web(vLogin;21)-->
                    <button id="btn-close-ot" class="show-target" type="button">Cerrar</button>
                <!--#4dendif-->
                    <button id="btn-open-ot" class="hide-target" type="button">Abrir</button>
            <!--#4dendif-->
        <!--#4dendif-->
    </p>
</div>


<script type="text/javascript">
    var autoresize = function(target){
        target.height(target[0].scrollHeight);
    }
    $(document).ready(function() {
        autoresize($("#idcomment-otxx"));
        $("#idcomment-otxx").change(function(){
            autoresize($(this));
        });
    });
</script>
