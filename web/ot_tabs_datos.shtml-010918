                        <!--#4dendif-->
                    </div>
                <!--#4dendif-->
                <!--#4dif (aTipoAsig{aLoginAsig}="INVITADO") & (vDisabledCerrado="") -->
                    <div class="items-asignados-inv">
                        <!--#4dif (aVistoPorAsig{aLoginAsig})-->
                        <span class="check-ot" title="El participante ha visto la OT">✓</span>
                        <!--#4dendif-->
                        <!--#4dvar lowercase(aNombreAsig{aLoginAsig})-->
                        <a id="<!--#4dvar aLoginAsig{aLoginAsig}-->" class="delete-part-ot">x</a>
                    </div>
                <!--#4dendif-->
            <!--#4dendloop-->
            </div>
        </div>
