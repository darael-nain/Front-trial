    <div class="box-hrs-vcto" style="margin-left: 40px; text-align: left !important;">
        <div>

        <!--#4dif vCodTipoOt="PROYECTO"-->

            <!--#4DIF _V3_verifica_permisos_web(vLogin;494)-->
