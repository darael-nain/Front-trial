<html>
	<head>
		<!--#4DSCRIPT/_V3_proxy_getListCotByProyecto-->
		<meta charset="utf-8">
		<title>Compras</title>
		<script>
		$(document).ready(function() {
			var container = $('section.sheet-list-compras');
			var id = container.data('id');
			var detail = container.data('detail');
			var tbody = container.find('table > tbody');
			var tfoot = container.find('table > tfoot');

			var total_fxr_otros_v2 = 0;

			var loadComprasNegocio = function(data) {

				total_fxr_otros_v2 = data.total_fxr_otros_v2;

				// Elimina todas las oc de la tabla
				tbody.find("*").remove();

				var sumaNetos = 0;
				var sumaTotal = 0;

				var htmlObject;
				$.each(data.rows, function(key, item) {

					if(item.estado != "ANULADA" && !item.excluir_gasto){
						sumaNetos = sumaNetos + item.neto;
						sumaTotal = sumaTotal + ((item.total != 0)? item.total : item.neto);
						//sumaTotal = sumaTotal + ((item.neto != 0)? item.neto : item.total);
					}

					var v2 = "";
					if(item.version != "V3"){
						v2 = '<strong style="font-size:10px!important;font-weight:bold">*</strong>';
					}

					var tipo = "";
					if (item.tipo =='INTERNO' || item.tipo =='INTERIOR' || item.tipo=='ITEMSNV') {
						tipo = "DIRECTOS";
					}else{
						tipo = "OTROS";
					}

					//htmlObject = $('<tr data-id="'+item.id+'" data-tipo="'+tipo+'" data-version="'+item.version+'" data-neto="'+item.neto+'" data-total="'+item.total+'" data-estado="'+item.estado+'">'+
					htmlObject = $('<tr data-id="'+item.id+'" data-tipo="'+tipo+'" data-version="'+item.version+'" data-neto="'+item.neto+'" data-total="'+((item.neto != 0)? item.neto : item.total)+'" data-estado="'+item.estado+'">'+
								'<td>'+v2+'</td>' +
								'<td>'+item.folio+'</td>' +
								'<td>'+item.emisor+'</td>' +
								'<td>'+item.fecha+'</td>' +
								'<td>'+item.factura_tipo+'</td>' +
								'<td class="left">'+item.proveedor+'</td>' +
								'<td class="left">'+item.referencia+'</td>' +
								//'<td class="currency">'+item.neto+'</td>' +
								'<td class="currency"' + ( (item.excluir_gasto)? ' style="color: blue;"' : '') + '>'+((item.total != 0)? item.total : item.neto)+'</td>' +
								//'<td class="currency">'+((item.neto != 0)? item.neto : item.total)+'</td>' +
								'<td class="status">'+item.estado+'</td>' +
								'<td>'+((item.saldo_consolidar<=0)? '<input disabled checked type="checkbox">': '<input disabled type="checkbox">')+'</td>' +
								'</tr>');
					tbody.append(htmlObject);
				});

				var htmlObject;
				var total_footer = 0;

				htmlObject = $('<tr>'+
							'<th></th>' +
							'<th></th>' +
							'<th></th>' +
