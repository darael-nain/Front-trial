							'<th></th>' +
							'<th></th>' +
							'</tr>');
				tfoot.html(htmlObject);

				if (total_fxr_otros_v2 > 0){
					htmlObject2 = $('<tr>'+
								'<th></th>' +
								'<th></th>' +
								'<th></th>' +
								'<th></th>' +
								'<th></th>' +
								'<th></th>' +
								'<th class="right" style="text-transform:none">Otros gastos en rendición:</th>' +
								'<th class="currency right" style="border-bottom:1px solid gray">'+total_fxr_otros_v2+'</th>' +
								'<th></th>' +
								'<th></th>' +
								'</tr>');
					tfoot.append(htmlObject2);

					var total_total = sumaNetos + total_fxr_otros_v2;
					htmlObject2 = $('<tr>'+
								'<th></th>' +
								'<th></th>' +
								'<th></th>' +
								'<th></th>' +
								'<th></th>' +
								'<th></th>' +
								'<th></th>' +
								'<th class="currency right">'+total_total+'</th>' +
								'<th></th>' +
								'<th></th>' +
								'</tr>');
					tfoot.append(htmlObject2);
				}


				formatCurrency();

				$('table.gastos tbody').find('tr[data-estado="ANULADA"]').hide();

			};

