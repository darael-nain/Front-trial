	<body>
		<section class="sheet-list-compras sheet" data-id="<!--#4DTEXT id-->">

			<header style="display:none">
				<span>
					<input readonly name="oc[tipo_gastos][des]" placeholder="Seleccionar tipo" type="search" value="<!--#4DTEXT [Orden_de_compra]des_tipo_gasto-->">
					<button type="button" class="show tiposg">ver tipos</button>
				</span>
			</header>

			<table class="gastos">
				<thead>
					<tr>
						<th width=""></th>
						<th width="5%">Número</th>
						<th width="5%">Ejecutivo</th>
						<th width="10%">F.Emisión</th>
						<th width="10%">F. Realización</th>
						<th width="25%">Cliente</th>
						<th width="25%">Referencia</th>
						<th width="10%">Total neto[$]</th>
						<th width="10%">Estado</th>
						<th width="5%">Validada</th>
					</tr>
				</thead>
				<tbody class="ui-selectable">
                    <!--#4DLOOP [Nota_de_venta]-->
                    <tr data-id="<!--#4DVAR [Nota_de_venta]id_nv-->">
						<td></td>
						<td><!--#4DTEXT [Nota_de_venta]Id_Negocio--></td>
						<td><!--#4DTEXT [Nota_de_venta]ejecutivo_responsable--></td>
                        <td><!--#4DTEXT [Nota_de_venta]fecha_emision--></td>
						<td><!--#4DTEXT [Nota_de_venta]Fecha_Ingreso_Saldo--></td>
						<td><!--#4DTEXT [Nota_de_venta]razon_cliente--></td>
						<td><!--#4DTEXT [Nota_de_venta]referencia--></td>
						<td><!--#4DTEXT String([Nota_de_venta]Total_Neto;"$ ###.###.###.##0")--></td>
						<td><!--#4DTEXT [Nota_de_venta]Estado_NV--></td>
						<td><!--#4DIF [Nota_de_venta]Validada-->Sí<!--#4DELSE-->No<!--#4DENDIF--></td>
                    </tr>
                    <!--#4DENDLOOP-->
                </tbody>
			  	<tfoot></tfoot>
			</table>
		</section>
	</body>
