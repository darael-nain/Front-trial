<!DOCTYPE html>
<html>
	<!--#4DSCRIPT/_V3_proxy-->
	<head>
		<title>Reporte Estado Resultado</title>
		<meta charset="utf-8">
		<script type="text/javascript" src="/v3/views/reportes/script/content.js"></script>
		<script src="/v3/script/sorttable.js"></script>
		<script>
		var container = $('#container-reportes');
		var tbody = container.find('table.reportes > tbody');

		var getCategorias = function(){
			//unaBase.ui.block();
			var fields = '';
			var searchFields = $.param(unaBase.toolbox.search.advancedFilter);
			var serialFields = $('#search').serializeAnything(true);
			fields = searchFields + '&' + serialFields;
			// fields = serialFields ;
			
			$.ajax({
				url: '/4DACTION/_V3_getEstadoResultadoReporte',
				data: fields,
				dataType: 'json',
				success: function(data) {
					tbody.find('*').remove();
					$('#search').find('*').prop('disabled', true);
					var rows = '';

					// Venta por área de negocio
					var new_rows = '';
					var row_header = '\
						<tr class="title" style="background-color:white>\
							<th colspan="27">Venta por área de negocio</th>\
						</tr>';
					$.each(data.ventas.areas_negocio, function(key, item) {
						var is_filled_row = false;
						var row_body = '\
							<tr style="background-color:white;color:#08a86c;font-weight:bold">\
								<td>' + item.name + '</td>';
						$.each(item.months, function(subkey, subitem) {
							//subitem.value.toString().replace('.', ',')
							row_body+= '<td class="numeric currency" style="text-align: right;">'+ currency.symbol +'&nbsp;<input style="display: inline-block; width: 80px !important; padding: 0; border-bottom: none; color: inherit;" disabled value="' + $.number(subitem.value, currency.decimals, currency.decimals_sep, currency.thousands_sep) + '"></td>';
							row_body+= '<td class="numeric percent"><input style="display: inline-block; width: 35px !important; padding: 0; border-bottom: none; color: inherit;" disabled value="' + (subitem.percent * 100.00).toFixed(2).toString().replace('.', ',') + '">&nbsp;%</td>';
							is_filled_row|= (subitem.value != 0);
						});
						row_body+= '</tr>';
						if (is_filled_row) {
							new_rows+= row_body;
						}
					});
					var row_footer = '\
						<tr>\
							<th>Suma ventas</th>';
					$.each(data.ventas.suma.months, function(key, item) {
						//item.value.toString().replace('.', ',')
						row_footer+= '<th class="numeric currency" style="text-align: right;">'+ currency.symbol +'&nbsp;<input style="display: inline-block; width: 80px !important; padding: 0; border-bottom: none; color: inherit;" disabled value="' + $.number(item.value, currency.decimals, currency.decimals_sep, currency.thousands_sep) + '"></th>';
						row_footer+= '<th class="numeric percent"><input style="display: inline-block; width: 35px !important; padding: 0; border-bottom: none; color: inherit;" disabled value="' + (item.percent * 100.00).toFixed(2).toString().replace('.', ',') + '">&nbsp;%</th>';
					});
					row_footer+= '</tr>';
					if (new_rows != '') {
						rows+= row_header + new_rows + row_footer;
					}

					// Costos directos
					var new_rows = '';
					var row_header = '\
						<tr class="title">\
							<th colspan="27">Costos directos</th>\
						</tr>';

					$.each(data.costos_directos.tipos, function(key, item) {
						var is_filled_row = false;
						var row_body = '\
							<tr style="background-color:white;color:#FE6862;font-weight:bold">\
								<td>' + item.name + '</td>';
						$.each(item.months, function(subkey, subitem) {
							//subitem.value.toString().replace('.', ',')
							row_body+= '<td class="numeric currency" style="text-align: right;">'+ currency.symbol +'&nbsp;<input style="display: inline-block; width: 80px !important; padding: 0; border-bottom: none; color: inherit;" disabled value="' + $.number(subitem.value, currency.decimals, currency.decimals_sep, currency.thousands_sep) + '"></td>';
							row_body+= '<td class="numeric percent"><input style="display: inline-block; width: 35px !important; padding: 0; border-bottom: none; color: inherit;" disabled value="' + (subitem.percent * 100.00).toFixed(2).toString().replace('.', ',') + '">&nbsp;%</td>';
							is_filled_row|= (subitem.value != 0);
						});
						row_body+= '</tr>';
						if (is_filled_row) {
							new_rows+=row_body;
						}
					});
					var row_footer = '\
						<tr>\
							<th>Suma costos directos</th>';
					$.each(data.costos_directos.suma.months, function(key, item) {
						// item.value.toString().replace('.', ',')
						row_footer+= '<th class="numeric currency" style="text-align: right;">'+ currency.symbol +'&nbsp;<input style="display: inline-block; width: 80px !important; padding: 0; border-bottom: none; color: inherit;" disabled value="' + $.number(item.value, currency.decimals, currency.decimals_sep, currency.thousands_sep) + '"></th>';
						row_footer+= '<th class="numeric percent"><input style="display: inline-block; width: 35px !important; padding: 0; border-bottom: none; color: inherit;" disabled value="' + (item.percent * 100.00).toFixed(2).toString().replace('.', ',') + '">&nbsp;%</th>';
					});
					row_footer+= '</tr>';
					if (new_rows != '') {
						// rows+= row_header + new_rows + row_footer;
						rows+= new_rows;
					}

					// Resultado operación
					rows+= '\
						<tr class="subtotal">\
							<th>Resultado operación</th>';
					$.each(data.resultado_operacion.months, function(key, item) {
						//item.value.toString().replace('.', ',')
						rows+= '<th class="' + (item.value < 0? 'negative ' : '') + 'numeric currency" style="text-align: right;">'+ currency.symbol +'&nbsp;<input style="display: inline-block; width: 80px !important; padding: 0; border-bottom: none; color: inherit;" disabled value="' + $.number(item.value, currency.decimals, currency.decimals_sep, currency.thousands_sep) + '"></th>';
						rows+= '<th class="' + (item.percent < 0? 'negative ' : '') + 'numeric percent"><input style="display: inline-block; width: 35px !important; padding: 0; border-bottom: none; color: inherit;" disabled value="' + (item.percent * 100.00).toFixed(2).toString().replace('.', ',') + '">&nbsp;%</th>';
					});
					rows+= '</tr>';

					// Gastos generales
					var new_rows = '';
					var row_header = '\
						<tr class="title">\
							<th colspan="27">Gastos generales</th>\
						</tr>';

					$.each(data.gastos_generales.clasificaciones, function(key, item) {
						var is_filled_row = false;
						var row_body = '\
							<tr style="background-color:white;color:#FE6862;font-weight:bold">\
								<td>' + item.name + '</td>';
						$.each(item.months, function(subkey, subitem) {
							//subitem.value.toString().replace('.', ',')
							row_body+= '<td class="numeric currency" style="text-align: right;">'+ currency.symbol +'&nbsp;<input style="display: inline-block; width: 80px !important; padding: 0; border-bottom: none; color: inherit;" disabled value="' + $.number(subitem.value, currency.decimals, currency.decimals_sep, currency.thousands_sep) + '"></td>';
							row_body+= '<td class="numeric percent"><input style="display: inline-block; width: 35px !important; padding: 0; border-bottom: none; color: inherit;" disabled value="' + (subitem.percent * 100.00).toFixed(2).toString().replace('.', ',') + '">&nbsp;%</td>';
							is_filled_row|= (subitem.value != 0);
						});
						row_body+= '</tr>';
						if (is_filled_row) {
							new_rows+=row_body;
						}
					});

					var row_footer = '\
						<tr>\
							<th>Suma gastos generales</th>';
					$.each(data.gastos_generales.suma.months, function(key, item) {
						//item.value.toString().replace('.', ',')
						row_footer+= '<th class="numeric currency" style="text-align: right;">'+ currency.symbol +'&nbsp;<input style="display: inline-block; width: 80px !important; padding: 0; border-bottom: none; color: inherit;" disabled value="' + $.number(item.value, currency.decimals, currency.decimals_sep, currency.thousands_sep) + '"></th>';
						row_footer+= '<th class="numeric percent"><input style="display: inline-block; width: 35px !important; padding: 0; border-bottom: none; color: inherit;" disabled value="' + (item.percent * 100.00).toFixed(2).toString().replace('.', ',') + '">&nbsp;%</th>';
					});
					row_footer+= '</tr>';
					if (new_rows != '') {
						rows+= row_header + new_rows + row_footer;
					}

					tbody.html(rows);

					var resultadoMonthObject = $(".resultado-month");
					$.each(data.resultado.months, function(key, item) {
						var index_value = 2 * key;
						var index_percent = (2 * key) + 1;
						var resultadoMonthValue = resultadoMonthObject.eq(index_value);
						var resultadoMonthPercent = resultadoMonthObject.eq(index_percent);
						//resultadoMonthValue.html(item.value.toString().replace('.', ',')).number(true, 0, ',', '.');
						resultadoMonthValue.html($.number(item.value, currency.decimals, currency.decimals_sep, currency.thousands_sep));
						resultadoMonthPercent.html((item.percent * 100).toString().replace('.', ',')).number(true, 2, ',', '.');
						if (item.value < 0) {
							resultadoMonthValue.addClass('negative');
						}
						if (item.percent < 0) {
							resultadoMonthPercent.addClass('negative');
						}
					});


					//tbody.find('.numeric.currency input').number(true, 0, ',', '.', true);
					//tbody.find('.numeric.percent span').number(true, 2, ',', '.', true);

					$('#search').find('*').prop('disabled', false);

					//unaBase.ui.unblock();
				},
				error: function(xhr, text, error) {
					console.log("error:" + error);
				}
			});
		}

		$(document).ready(function() {
			unaBase.toolbox.init();
			unaBase.toolbox.search.init({
				callback: function() {
					var status = $('#search').find('*').prop('disabled');
					if (!status) {
						getCategorias();
					}
					return false;
				},
				inflection: {
					singular: 'categoria',
					plural: 'categorias',
					none: 'ninguna'
				},
				filters: [
					{ name: 'date_from', type: 'year', caption: 'Año', currentYear: true },
					{ name: 'area_negocio_reporte', type: 'autocomplete', caption: 'Área de negocio', dataSource: 'getAreaNegocio' },
					{ name: 'estado_compras', type: 'autocomplete', caption: 'Estado de las compras', dataObject: [
						{
							text: 'Abiertas para compras'
						},
						{
							text: 'Cerradas para compras'
						}
					]}
					// ,
					// { name: 'tipo_fecha', type: 'radio', preventSearch: true, caption: 'Tipo de fecha', options: [
					// 	{ caption: 'F. Asignación', name: 'fecha_asignacion', value: true },
					// 	{ caption: 'F. Realización', name: 'fecha_realizacion', value: false },
					// 	{ caption: 'F. Facturación', name: 'fecha_facturacion', value: false }
					// ] }
				],
				hideSearchBox: true
			});

			unaBase.toolbox.menu.init({
				entity: 'estado_resultados',
				buttons: ['exit', 'export_list']
			});

		});
		</script>
		<style type="text/css">


		.name{color: black;}
		.name_rojo{color: red;}
		.name > span{color: #AF6D44;}
		.ventas{color: black;}
		.ventas > span{color: black;}

		div.totales {
            	position: absolute;
            	right: 15px;
            	bottom: 30px;
            	z-index: 1000;
            	width: 515px;
            	height: 190px;
            	padding: 3px;

            	opacity: 0.9;
            	background-color: darkgrey;
            	color: black;
            	font-size: 14px;
            	cursor: move;
            	border-radius: 4px;
            	box-shadow: -4px 4px 8px 1px rgba(48, 48, 48, 0.75);
            }

            div.totales > span {
            	display: block;
            }

            div.totales > span > span {
            	display: inline-block;
            }

            div.totales > span > span:first-of-type {
            	width: 85px;
            }

            div.totales > span > span:nth-of-type(2) {
            	width: 135px;
            }

            div.totales > span > span:nth-of-type(3) {
            	width: 135px;
            }

            div.totales > span > span:nth-of-type(4) {
            	width: 145px;
            }




            div.totales > span > span.numeric {
            	text-align: right;
            }

            span.total_comisiones {
				/* color: #CF8D64; */
				background-color: #2DC800;
				color: black;
				margin-top: 10px;
			}

			span.total_ventas {
				/* color: #64CF8D; */
				background-color: #FFFF11;
				color: black;
				text-align: left!important;
			}

			span.total_descuentos {
				background-color: #FF3333;
				color: black;
			}

			span.total_Facturado {
				background-color: #F781BE;
				color: black;
			}

			span.total_diferencia {
				background-color: #22FF22;
				color: black;
			}

			span.sumaTotalesVentas {
				background-color: #8258FA;
				color: black;
			}

			span.saldo_por_cobrar {
				background-color: #FFFF11;
				color: black;
			}

			span.real {
				-webkit-filter: hue-rotate(270deg);
			}

			section.sheet table.items{
				width: 100% !important;
				margin-left: auto;
				margin-right: auto;
			}

			.label{
				color:black!important;
				font-weight:bold!important;
				padding:3px!important;;
				border-radius:2px!important;
				display:inline-block!important;
				min-width:80px!important;
			}

			.fn_blue{
				background-color: #2F74D0
			}
			.fn_yellow{
				background-color: #fde601;

			}

			.fn_percent{
				min-width: 50px !important;
				background-color: #fde601;
			}

			.fn_green{
				background-color: #3bc372
			}

			.fn_red{
				background-color: #ff6961
			}

			.fn_orange{
				background-color: #FFB347
			}

			.uno{
				display:none;
			}

			.htitle{
				padding:5px 0 5px 0;
				font-weight: bold;
				text-transform: uppercase;
			}

			.title > th {
				background-color: darkgrey !important;
				color: white !important;
			}

			.subtotal > th {
				background-color: rgb(247,247,221) !important;
				border-top: 3px solid lightgrey !important;
				color: rgb(0,51,51) !important;
			}

			tr:not(.title) > td:nth-of-type(2)::before {
				content: '' !important;
			}

			thead tr > *:not(:first-of-type),
			tfoot tr > *:nth-of-type(2n) {
				border-left: 1px solid darkgrey;
			}

			tbody tr:not(.title) > *:nth-of-type(2n) {
				border-left: 1px solid darkgrey;
			}

			.negative, .negative span {
				color: red !important;
			}


			/* -- ini -- modificado para mostrar boton volver arriba y los filtros abajo, gin, 28-02-18 */
			li[data-name="exit"]{
				top: 10px;
			    left: 0;
			    position: absolute;
			}
			#search{
			    display: inline-block;
			    margin: 30px 0 0 -5px;
			}
			#search input[name="estado_compras"]{
			   width: 110px!important;
			}
			/* -- fin -- modificado para mostrar boton volver arriba y los filtros abajo, gin, 28-02-18 */

		</style>
		<script>
			$(document).ready(function() {
				$('div.totales').draggable({ containment: "parent" });
				$('.symbol-money').text(currency.symbol);
			});
		</script>
	</head>
	<body>
		<section class="sheet items" id="container-reportes" style="height:200px;overflow:auto;">
			<!--<input type="button" id="btnExport" value=" Export Table data into Excel " />-->
			<h3 class="htitle">Estado resultado</h3>
			<table class="items reportes" style="border:2px solid lightgray">
				<thead>
					<tr>
						<th style="text-align:center;background-color:black"></th>
						<th colspan="2" style="text-align: center;">Enero</th>
						<th colspan="2" style="text-align: center;">Febrero</th>
						<th colspan="2" style="text-align: center;">Marzo</th>
						<th colspan="2" style="text-align: center;">Abril</th>
						<th colspan="2" style="text-align: center;">Mayo</th>
						<th colspan="2" style="text-align: center;">Junio</th>
						<th colspan="2" style="text-align: center;">Julio</th>
						<th colspan="2" style="text-align: center;">Agosto</th>
						<th colspan="2" style="text-align: center;">Septiembre</th>
						<th colspan="2" style="text-align: center;">Octubre</th>
						<th colspan="2" style="text-align: center;">Noviembre</th>
						<th colspan="2" style="text-align: center;">Diciembre</th>
						<th colspan="2" style="text-align: center;">Acumulado</th>
					</tr>
				</thead>
				<tfoot>
					<tr>
				        <th>Resultado final</th>
				        <th style="text-align: right;"><span class="label fn_yellow"><label class="symbol-money"></label> <span class="resultado-month">0</span></th>
						<th style="text-align: right;"><span class="label fn_percent"><span class="resultado-month">0</span> %</th>
						<th style="text-align: right;"><span class="label fn_yellow"><label class="symbol-money"></label> <span class="resultado-month">0</span></th>
						<th style="text-align: right;"><span class="label fn_percent"><span class="resultado-month">0</span> %</th>
						<th style="text-align: right;"><span class="label fn_yellow"><label class="symbol-money"></label> <span class="resultado-month">0</span></th>
						<th style="text-align: right;"><span class="label fn_percent"><span class="resultado-month">0</span> %</th>
						<th style="text-align: right;"><span class="label fn_yellow"><label class="symbol-money"></label> <span class="resultado-month">0</span></th>
						<th style="text-align: right;"><span class="label fn_percent"><span class="resultado-month">0</span> %</th>
						<th style="text-align: right;"><span class="label fn_yellow"><label class="symbol-money"></label> <span class="resultado-month">0</span></th>
						<th style="text-align: right;"><span class="label fn_percent"><span class="resultado-month">0</span> %</th>
						<th style="text-align: right;"><span class="label fn_yellow"><label class="symbol-money"></label> <span class="resultado-month">0</span></th>
						<th style="text-align: right;"><span class="label fn_percent"><span class="resultado-month">0</span> %</th>
						<th style="text-align: right;"><span class="label fn_yellow"><label class="symbol-money"></label> <span class="resultado-month">0</span></th>
						<th style="text-align: right;"><span class="label fn_percent"><span class="resultado-month">0</span> %</th>
						<th style="text-align: right;"><span class="label fn_yellow"><label class="symbol-money"></label> <span class="resultado-month">0</span></th>
						<th style="text-align: right;"><span class="label fn_percent"><span class="resultado-month">0</span> %</th>
						<th style="text-align: right;"><span class="label fn_yellow"><label class="symbol-money"></label> <span class="resultado-month">0</span></th>
						<th style="text-align: right;"><span class="label fn_percent"><span class="resultado-month">0</span> %</th>
						<th style="text-align: right;"><span class="label fn_yellow"><label class="symbol-money"></label> <span class="resultado-month">0</span></th>
						<th style="text-align: right;"><span class="label fn_percent"><span class="resultado-month">0</span> %</th>
						<th style="text-align: right;"><span class="label fn_yellow"><label class="symbol-money"></label> <span class="resultado-month">0</span></th>
						<th style="text-align: right;"><span class="label fn_percent"><span class="resultado-month">0</span> %</th>
						<th style="text-align: right;"><span class="label fn_yellow"><label class="symbol-money"></label> <span class="resultado-month">0</span></th>
						<th style="text-align: right;"><span class="label fn_percent"><span class="resultado-month">0</span> %</th>
						<th style="text-align: right;"><span class="label fn_yellow"><label class="symbol-money"></label> <span class="resultado-month">0</span></th>
						<th style="text-align: right;"><span class="label fn_percent"><span class="resultado-month">0</span> %</th>
			        </tr>

				</tfoot>

				<tbody></tbody>
			</table>
		</section>
	</body>
</html>
