<!DOCTYPE html>
<html>
<head>
	<!--#4DSCRIPT/_V3_proxy-->
	<meta charset="utf-8">
	<title>Reportes</title>
	<style>
		.options > h1 {
			font-size: 14px;
		}
		.options > ul {
			margin-top: 15px;
			font-size: 12px;
		}
		.options > ul > li {
			margin-bottom: 5px;
			border:1px solid lightgray;
			background-color:white;
			color:#00a96c;
			padding:5px;
			margin:2px;
			width:400px;
			cursor: pointer;
			font-weight: bold;
			border-radius:2px;
		}
		.options > ul > li div {
			color:black;
			font-weight:normal;
		}
	</style>
</head>
<body>
	<section class="options">
		<ul>
			<li onclick="unaBase.loadInto.viewport('/v3/views/reportes/reportes.shtml'); return false;">
				<a href="#" onclick="unaBase.loadInto.viewport('/v3/views/reportes/reportes.shtml'); return false;">Reportes gráficos</a>
				<div style="display:none">
					<div>- Ventas por clientes, historico</div>
					<div>- Ventas por servicios año en curso</div>
					<div>- Ventas por mes , año en curso</div>
					<div>- Gastos por mes , año en curso</div>
					<div>- Facturacion por mes</div>
					<div>- Ventas y Gastos , año en curso</div>
					<div>- Utilidad Proyectada vs Utilidad Real</div>
					<div>- Ventas por año</div>
					<div>- Ventas vs gastos por año</div>
				</div>
			</li>

			<li onclick="unaBase.loadInto.viewport('/v3/views/reportes/reportes_por_servicio.shtml'); return false;"><a href="#" onclick="unaBase.loadInto.viewport('/v3/views/reportes/reportes_por_servicio.shtml'); return false;">Reportes por Servicios</a></li>

			<!--<li onclick="unaBase.loadInto.viewport('/v3/views/reportes/reporte_online.shtml'); return false;"><a href="#" onclick="unaBase.loadInto.viewport('/v3/views/reportes/reporte_online.shtml'); return false;">Reporte Online</a></li>-->

			<li onclick="unaBase.loadInto.viewport('/v3/views/reportes/reporte_facturacion_por_cliente.shtml'); return false;"><a href="#" onclick="unaBase.loadInto.viewport('/v3/views/reportes/reporte_facturacion_por_cliente.shtml'); return false;">Reporte Facturación por Cliente</a></li>

			<li onclick="unaBase.loadInto.viewport('/v3/views/reportes/reporte_ventas_por_areanegocio.shtml'); return false;"><a href="#" onclick="unaBase.loadInto.viewport('/v3/views/reportes/reporte_ventas_por_areanegocio.shtml'); return false;">Reporte Ventas por Área de Negocio</a></li>

			<li onclick="unaBase.loadInto.viewport('/v3/views/reportes/reporte_ventas_por_cliente.shtml'); return false;"><a href="#" onclick="unaBase.loadInto.viewport('/v3/views/reportes/reporte_ventas_por_cliente.shtml'); return false;">Reporte Ventas por Cliente</a></li>

			<!--#4DIF _V3_marcaEnabled-->
			<li onclick="unaBase.loadInto.viewport('/v3/views/reportes/reporte_ventas_por_marca.shtml'); return false;"><a href="#" onclick="unaBase.loadInto.viewport('/v3/views/reportes/reporte_ventas_por_marca.shtml'); return false;">Reporte Ventas por Marca</a></li>
			<!--#4DENDIF-->

			<li onclick="unaBase.loadInto.viewport('/v3/views/reportes/reporte_cotizaciones_por_ejecutivo.shtml'); return false;"><a href="#" onclick="unaBase.loadInto.viewport('/v3/views/reportes/reporte_cotizaciones_por_ejecutivo.shtml'); return false;">Reporte Cotizaciones por Ejecutivo</a></li>

			<li onclick="unaBase.loadInto.viewport('/v3/views/reportes/reporte_cotizaciones_por_cliente.shtml'); return false;"><a href="#" onclick="unaBase.loadInto.viewport('/v3/views/reportes/reporte_cotizaciones_por_cliente.shtml'); return false;">Reporte Cotizaciones por Cliente</a></li>

			
			<li onclick="unaBase.loadInto.viewport('/v3/views/reportes/reporte_pagos_por_proveedor.shtml'); return false;"><a href="#" onclick="unaBase.loadInto.viewport('/v3/views/reportes/reporte_pagos_por_proveedor.shtml'); return false;">Reporte pagos por proveedor</a></li>

			<!-- <li><a href="#" onclick="unaBase.loadInto.viewport('/v3/views/reportes/reporte_cotizaciones_con_gastos_o_facturas.shtml'); return false;">Reporte Cotizaciones con gastos o facturas</a></li> -->

			<li onclick="unaBase.loadInto.viewport('/v3/views/reportes/reporte_estado_resultado.shtml'); return false;"><a href="#" onclick="unaBase.loadInto.viewport('/v3/views/reportes/reporte_estado_resultado.shtml'); return false;">Reporte estado resultado</a></li>
		</ul>
	</section>
</body>
</html>
