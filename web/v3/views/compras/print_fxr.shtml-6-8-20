<!--#4DSCRIPT/_V3_serverInfo-->

<section>
	<h2>Totales (<!--#4DIF [Orden_de_compra]des_tipo_gasto = "FACTORING"-->Factoring<!--#4DELSE-->Rendición<!--#4DENDIF-->)</h2>
	<article class="fn-totales">
		<table class="right" width="99%">
			<tbody>
				<tr>
					<td width="80%">Solicitado <!--#4DVAR _V3_defaultCurrencySymbol--> </td>
					<td width="20%"><!--#4DTEXT _V3_formatCurrency(Round([Orden_de_compra]Total_OC;_V3_defaultCurrencyDecimals))--></td>
				</tr>
				<tr>
					<td width="80%">Pagado <!--#4DVAR _V3_defaultCurrencySymbol--></td>
					<td width="20%"><!--#4DTEXT _V3_formatCurrency(Round([Orden_de_compra]Total_Abonos;_V3_defaultCurrencyDecimals))--></td>
				</tr>
				<tr>
					<td width="80%">Rendido (justificado) <!--#4DVAR _V3_defaultCurrencySymbol--></td>
					<td width="20%"><!--#4DTEXT _V3_formatCurrency(Round([Orden_de_compra]v3_total_justificado;_V3_defaultCurrencyDecimals))--></td>
				</tr>
				<tr>
					<td width="80%">Despositado (o devuelto) <!--#4DVAR _V3_defaultCurrencySymbol--></td>
					<td width="20%"><!--#4DTEXT _V3_formatCurrency(Round([Orden_de_compra]fxr_total_ingresos;_V3_defaultCurrencyDecimals))--></td>
				</tr>
				<tr>
					<td width="80%">Saldo <!--#4DVAR _V3_defaultCurrencySymbol--></td>
					<td width="20%" ><!--#4DTEXT _V3_formatCurrency(Round([Orden_de_compra]fxr_saldo_total;_V3_defaultCurrencyDecimals))--></td>
				</tr>
			</tbody>
		</table>
	</article>
</section>
<section>

<!--#4DIF vCantDtc > 0-->
	<h2><!--#4DHTML vCantDtc--> Documento(s) de compra(s)</h2>
	<article>
	 	<table class="dtcs borders" width="99%">
			<thead>
				<tr>
					<th width="1%" class="center">Nro.</th>
					<th width="13%" class="center">Documento</th>
					<th width="19%" class="center">Proveedor</th>								
					<th width="19%" class="center">Referencia</th>							
					<th width="12%" class="center">Emisión</th>
					<th width="12%" class="center">Código</th>								
					<th width="12%" class="center">Neto[<!--#4DVAR _V3_defaultCurrencySymbol-->]</th>
					<th width="12%" class="center">Total[<!--#4DVAR _V3_defaultCurrencySymbol-->]</th>		
				</tr>
			</thead>
			<tbody class="ui-selectable">
				<!--#4DLOOP [Doc_Tributario_Compra]-->
					<tr>
						<td class="center"><!--#4DIF [Doc_Tributario_Compra]has_attachment--><a href="<!--#4DTEXT _V3_base_url-->/4DACTION/_V3_getUpload?index=Doc_Tributario_Compra|<!--#4DTEXT [Doc_Tributario_Compra]ID_DOC-->"><!--#4DHTML [Doc_Tributario_Compra]FOLIO_DOCUMENTO--></a><!--#4DELSE--><!--#4DHTML [Doc_Tributario_Compra]FOLIO_DOCUMENTO--><!--#4DENDIF--></td>
						<td class="center"><!--#4DHTML [Doc_Tributario_Compra]des_tipo_doc--></td>
						<td style="text-align:left!important"><!--#4DHTML [Doc_Tributario_Compra]RAZON_SOCIAL--></td>
						<td style="text-align:left!important"><!--#4DHTML [Doc_Tributario_Compra]REFERENCIA_DOCUMENTO--></td>
						<td class="center"><!--#4DHTML [Doc_Tributario_Compra]FECHA_EMISION--></td>
						<td class="center"><span style="display:inline-block!important"><!--#4DHTML [Doc_Tributario_Compra]v3_codigo_servicio--></span><!--#4DIF vIncluirCodContable--><span style="display:inline-block!important;margin-left:5px!important;font-weight:bold"><!--#4DHTML [Doc_Tributario_Compra]v3_cod_contable--></span><!--#4DENDIF--></td>
						<td class="right"><!--#4DHTML _V3_formatCurrency(Round([Doc_Tributario_Compra]TOTAL_NETO;_V3_defaultCurrencyDecimals))--></td>
						<td class="right"><!--#4DHTML _V3_formatCurrency(Round([Doc_Tributario_Compra]TOTAL_DOCUMENTO;_V3_defaultCurrencyDecimals))--></td>
					</tr>
				<!--#4DENDLOOP-->
			</tbody>
			<tfoot>
				<tr>
					<th colspan="6" style="border:0px"></th>
					<th class="right" style="border:0px"><!--#4DHTML _V3_formatCurrency(Round(vSumaJustificadoNetoFxr;_V3_defaultCurrencyDecimals))--></th>
					<th class="right" style="border:0px"><!--#4DHTML _V3_formatCurrency(Round(vSumaJustificadoTotalFxr;_V3_defaultCurrencyDecimals))--></th>	
				</tr>										
			</tfoot>
		</table>
	  </article>
<!--#4DELSE-->
	<h2>No existen documentos de compras asociados</h2>
<!--#4DENDIF--> 
</section>

<!--#4DIF Size of array(aid_dtc_nc) > 0-->
<section>
  <h2><!--#4DHTML Size of array(aid_dtc_nc)--> Notas(s) de crédito</h2>
  <article>
    <table class="dtcs borders" width="99%">
      <thead>
        <tr>
          <th class="center" width="5%">Número</th>
          <th class="center" width="5%">Emisión</th>
          <th class="center" width="5%">Factura Ref.</th>
          <th class="center" width="15%">Proveedor</th>
          <th class="center" width="5%">Motivo</th>
          <!--<th class="center" width="15%">Referencia</th>-->            
          <th class="center" width="10%">Neto [<!--#4DVAR _V3_defaultCurrencySymbol-->]</th>
          <!--<th class="right" width="10%">Exento [<!- -#4DVAR _V3_defaultCurrencySymbol- ->]</th>
          <th class="right" width="10%">Impuesto [<!- -#4DVAR _V3_defaultCurrencySymbol- ->]</th>
          <th class="right" width="10%">Adicional [<!- -#4DVAR _V3_defaultCurrencySymbol- ->]</th>-->
          <th class="center" width="10%">Total [<!--#4DVAR _V3_defaultCurrencySymbol-->]</th>        
        </tr>
      </thead>
      <tbody class="ui-selectable">
        <!--#4DLOOP aid_dtc_nc-->
          <tr>
            <td class="center"><!--#4DHTML afolio_dtc_nc{aid_dtc_nc}--></td>
            <td class="center"><!--#4DHTML afecha_dtc_nc{aid_dtc_nc}--></td>
            <td class="center"><!--#4DHTML afolio_factura_dtc_nc{aid_dtc_nc}--></td>
            <td class="center"><!--#4DHTML arazon_dtc_nc{aid_dtc_nc}--></td>         
            <td class="center"><!--#4DHTML amotivo_factura_dtc_nc{aid_dtc_nc}--></td>
            <!--<td class="center"><!- -#4DHTML aref_dtc_nc{aid_dtc_nc}- -></td>-->
            <td class="right"><!--#4DHTML  _V3_formatCurrency(Round(aneto_dtc_nc{aid_dtc_nc};_V3_defaultCurrencyDecimals))--></td>
            <!--<td class="right"><!- -#4DHTML aexento_dtc_nc{aid_dtc_nc}- -></td>
            <td class="center"><!- -#4DHTML aimpuesto_dtc_nc{aid_dtc_nc}- -></td>
            <td class="center"><!- -#4DHTML aadicional_dtc_nc{aid_dtc_nc}- -></td>-->
            <td class="center"><!--#4DHTML  _V3_formatCurrency(Round(atotal_dtc_nc{aid_dtc_nc};_V3_defaultCurrencyDecimals))--></td>
          </tr>
        <!--#4DENDLOOP--> 
      </tbody>
      <tfoot style="display:none">
        <tr>
          <th colspan="6" style="border:0px"></th>
          <th class="right" style="border:0px"><!--#4DHTML _V3_formatCurrency(0)--></th>
          <th class="right" style="border:0px"><!--#4DHTML _V3_formatCurrency(0)--></th> 
        </tr>                   
      </tfoot>
    </table>
    </article>
</section>
<!--#4DENDIF--> 

<!--#4DIF [Orden_de_compra]des_tipo_gasto = "FACTORING"-->
	<section>
	<!--#4DIF vCantDTV > 0-->
		<h2><!--#4DHTML vCantDTV--> Documento(s) de venta(s)</h2>
		<article>
		 	<table class="dtcs borders" width="99%">
				<thead>
					<tr>
						<th width="1%" class="center">Nro.</th>
						<th width="13%" class="center">Tipo</th>
						<th width="19%" class="center">Cliente</th>								
						<th width="19%" class="center">Referencia</th>							
						<th width="12%" class="center">Estado</th>
						<th width="12%" class="center">Total [<!--#4DVAR _V3_defaultCurrencySymbol-->]</th>
					</tr>
				</thead>
				<tbody class="ui-selectable">
					<!--#4DLOOP aIdsDtvFactoring-->
						<tr>
							<td class="center"><!--#4DTEXT aFolioDtvFactoring{aIdsDtvFactoring}--></td>
							<td class="center"><!--#4DTEXT aTipoDtvFactoring{aIdsDtvFactoring}--></td>
							<td class="center"><!--#4DTEXT aClienteDtvFactoring{aIdsDtvFactoring}--></td>
							<td class="center"><!--#4DTEXT aRefDtvFactoring{aIdsDtvFactoring}--></td>
							<td class="center"><!--#4DTEXT aEstadoDtvFactoring{aIdsDtvFactoring}--></td>
							<td class="center"><!--#4DHTML  _V3_formatCurrency(Round(aTotalDtvFactoring{aIdsDtvFactoring};_V3_defaultCurrencyDecimals))--></td>
						</tr>
					<!--#4DENDLOOP-->
				</tbody>
				<tfoot>
					<tr>
						<th colspan="5" style="border:0px"></th>							
						<th class="right" style="border:0px"><!--#4DHTML _V3_formatCurrency(Round(vSumaDtvs;_V3_defaultCurrencyDecimals))--></th>	
					</tr>							
				</tfoot>
			</table>
		  </article>
	<!--#4DELSE-->
		<h2>No existen documentos de ventas asociadas</h2>
	<!--#4DENDIF--> 
</section>
<!--#4DENDIF-->

<section>
<!--#4DIF vCantPagos > 0-->
	<h2><!--#4DHTML vCantPagos--> Pago(s)</h2>
	<article>
	   	<table class="pagos borders" width="99%">
			<thead>
				<tr>
					<th class="center">Número</th>
					<th class="center">Emisión</th>
					<th class="center">Fecha de pago</th>								
					<th class="center">Tipo</th>
					<th class="center">Ch/Tr</th>				
					<th class="center">Estado</th>								
					<th class="center">Monto</th>							
				</tr>
			</thead>
			<tbody class="ui-selectable">
				<!--#4DLOOP aOCOP_id-->
					<tr>
						<td class="center"><!--#4DHTML aOCOP_folio{aOCOP_id}--></td>
						<td class="center"><!--#4DHTML aOCOP_fechaemision{aOCOP_id}--></td>
						<td class="center"><!--#4DHTML aOCOP_fechavencimiento{aOCOP_id}--></td>
						<td class="center"><!--#4DHTML aOCOP_tipo{aOCOP_id}--></td>         
