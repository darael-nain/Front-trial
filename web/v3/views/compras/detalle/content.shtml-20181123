		<script>		
			$(document).ready(function() {
				var container = $('.sheet-detalle-items-oc');
				var containerCompras = $('#sheet-compras');
				var targetObservacion = container.find('textarea[name="detail[descripcion_larga]"]');
				
				// var id = container.data('id');
				// var targetRow = containerCompras.find('table > tbody > tr[data-llave="'+ id +'"]');
				// var observacion = targetRow.find('input[name="oc[detalle_item][observacion_item]"]').val();
				// targetObservacion.val(observacion);

				// visualización objetos según estado de la compra
				var estado = containerCompras.data("estado");
				var folio = containerCompras.data("folio");
				var validada = containerCompras.find('input[name="oc[validado]"]').val();
				if (estado != "EMITIDA") {
					targetObservacion.prop('readonly', true);
				}else{
					if (folio != "") {
						if (validada){
							if (!access._450) { // modificar validadas
								targetObservacion.prop('readonly', true);
							}							
						}else{
							if(!(access._448 || access._450)) { // modificar validadas y no
								targetObservacion.prop('readonly', true);
			    			}
						}
					}
				}
			});
		</script>
