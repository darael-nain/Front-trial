html > body.home > section > section#viewport section.sheet > footer {
	margin-bottom: 5px;
}

html > body.home > section > section#viewport section.sheet > footer > article {
	position: relative;
}

html > body.home > section > section#viewport section.sheet > footer > article.general {
	position: fixed;
	top: 0;
	background: none !important;
}

html > body.home > section > section#viewport section.sheet > footer > article.general > h1 {
	display: none !important;
}

html > body.home > section > section#viewport section.sheet > footer > article > h2 > span > span.numeric.percent:before {
	content: "(";
}

html > body.home > section > section#viewport section.sheet > footer > article > h2 > span > span.numeric.percent:after {
	content: ")";
}

html > body.home > section > section#viewport section.sheet > footer > article input[name="cotizacion[montos][subtotal_neto]"].ajustado {
	color: rgb(67,175,124);
}

html > body.home > section > section#viewport section.sheet > footer > article > ul.editable {
	display: inline-block;
	width: calc(50% - 2px);
	margin-top: 35px;
	margin-bottom: 15px;
	vertical-align: top;
}

html > body.home > section > section#viewport section.sheet > footer > article > ul.editable > li.margin-after,
html > body.home > section > section#viewport section.sheet footer ul > li.margin-after{
	margin-bottom: 18px;
}

html > body.home > section > section#viewport section.sheet > footer > article > ul.editable > li.margin-before,
html > body.home > section > section#viewport section.sheet footer ul > li.margin-before{
	margin-top: 18px;
}

html > body.home > section > section#viewport section.sheet > footer > article > ul.editable > li > span:first-of-type {
	display: inline-block;
	width: calc(20% - 2px);
	font-weight: bold;
}

html > body.home > section > section#viewport section.sheet > footer > article > ul.editable > li > span:nth-of-type(2) {
	display: inline-block;
	vertical-align: middle;
}

html > body.home > section > section#viewport section.sheet > footer > article > ul.editable > li > span:nth-of-type(2):not(.ui-icon) {
	width: calc(60% - 2px);
}

html > body.home > section > section#viewport section.sheet > footer > article > ul.editable > li > span.main:nth-of-type(2) {
	width: calc(60% - 2px - 70px);
}

html > body.home > section > section#viewport section.sheet > footer > article > ul.editable > li > span.secondary:nth-of-type(3) {
	display: inline-block;
	width: calc(70px);
	text-align: right;
}

html > body.home > section > section#viewport section.sheet > footer > article > ul.editable > li > span.hidden {
	display: none;
}

html > body.home > section > section#viewport section.sheet > footer > article > button.expand {
	position: absolute;
	/* right: 23px; */
	right: 10px;
	top: 23px;
	display: inline-block;
	margin: 0 !important;
	padding: 0 !important;
	width: 18px !important;
	height: 18px !important;
}


html > body.home > section > section#viewport table,
.ui-dialog table {
	/* position: relative; */
	width: 100%;
	text-align: left;
	font-size: 10px;
	text-transform: uppercase;
}

html > body.home > section > section#viewport table > tbody,
html > body.home > section > section#viewport table > tfoot,
.ui-dialog table > tbody,
.ui-dialog table > tfoot {
	margin-top: 5px;
}

html > body.home > section > section#viewport table > tfoot,
.ui-dialog table > tfoot {
	font-weight: bold;
}

html > body.home > section > section#viewport table > thead > tr,
.ui-dialog table > thead > tr {
	background-color: rgb(189,189,192);
	color: white;
}

html > body.home > section > section#viewport table > thead > tr > th,
.ui-dialog table > thead > tr > th {
	text-align: center;
	text-transform: uppercase;
}

html > body.home > section > section#viewport table > tbody,
.ui-dialog table > tbody {
	color: rgb(103,103,103);
}

/* html > body.home > section > section#viewport table > tbody:empty:after,
.ui-dialog table > tbody:empty:after {
	content: "Aún no hay datos";
	display: table-cell;
} */

/*html > body.home > section > section#viewport table:not(fc-*) > tbody > tr:nth-of-type(odd),*/
html > body.home > section > section#viewport > table > tbody > tr:nth-of-type(odd),
html > body.home > section > section#viewport > *:not(.fc) table > tbody > tr:nth-of-type(odd),
.ui-dialog table > tbody > tr:nth-of-type(odd) {
	background-color: rgb(240,240,241);
}

/*html > body.home > section > section#viewport table:not(fc-*) > tbody > tr:nth-of-type(even),*/
html > body.home > section > section#viewport > table > tbody > tr:nth-of-type(even),
html > body.home > section > section#viewport > *:not(.fc) table > tbody > tr:nth-of-type(even),
.ui-dialog table > tbody > tr:nth-of-type(even) {
	background-color: white;
}

html > body.home > section > section#viewport table > tbody > tr[data-status="false"],
.ui-dialog table > tbody > tr[data-status="false"] {
	text-decoration: line-through;
}

html > body.home > section > section#viewport table > tbody > tr.ui-selecting,
.ui-dialog table > tbody > tr.ui-selecting {
	background: #FECA40;
	opacity: .7;
}

html > body.home > section > section#viewport table > tbody > tr.ui-selected,
.ui-dialog table > tbody > tr.ui-selected {
	background: #FECA40;
}

html > body.home > section > section#viewport > table > * > tr,
html > body.home > section > section#viewport > *:not(.fc) table > * > tr,
.ui-dialog table > * > tr {
	height: 39px;
	padding: 3px;
}

html > body.home > section > section#viewport table > * > tr > *,
.ui-dialog table > * > tr > * {
	padding: 3px;
	vertical-align: middle;
	text-align: center;
}

html > body.home > section > section#viewport table > * > tr > *.text,
.ui-dialog table > * > tr > *.text {
	text-align: left;
}

html > body.home > section > section#viewport table > * > tr > td.currency,
html > body.home > section > section#viewport table > * > tr > td.number,
.ui-dialog table > * > tr > td.currency,
.ui-dialog table > * > tr > td.number {
	position: relative;
	text-align: right;
	/* padding-left: 10px; */
	padding-left: 20px;
}

html > body.home > section > section#viewport table > tbody > tr > td.fit,
.ui-dialog table > tbody > tr > td.fit {
	width: 20px;
}

html > body.home > section > section#viewport table > tbody > tr > td.options > button,
.ui-dialog table > tbody > tr > td.options > button {
	width: 20px;
	height: 20px;
}

html > body.home > section > section#viewport table > * > tr > td.currency > span.symbol,
.ui-dialog table > * > tr > td.currency > span.symbol {
	position: absolute;
	left: 0;
	margin-left: 10px;
}

html > body.home > section > section#viewport table > * > tr > td.currency > span.negative,
.ui-dialog table > * > tr > td.currency > span.negative {
	color: red;
}

html > body.home > section > section#viewport table > * > tr > td > time > span,
.ui-dialog table > * > tr > td > time > span {
	color: rgb(67,165,24);
}


html > body.home > section > section#viewport section.sheet table.items,
