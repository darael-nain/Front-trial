@import url('menu.css');

html > body.home > div.toggle.menu {
	position: absolute;
	top: 5px;
	left: 5px;
	z-index: 999;
	width: 25px;
	height: 25px;
	background-image: url('html/body.home/section/div.toggle.menu.png');
	cursor: pointer;
	-webkit-filter: opacity(60%);
	transition: -webkit-filter .5s ease-in-out;
}

html > body.home > div.toggle.menu:hover,
html > body.home.tablet > div.toggle.menu {
	-webkit-filter: opacity(80%);
	transition: -webkit-filter .5s ease-in-out;
}

html > body.home > header > fieldset {
	position: absolute;
}

html > body.home > section {
	position: relative;
}

html > body.home > section > h1 {
	/* display: inline-block; */
	display: none !important;
	height: calc(32px - 10px * 2);
	margin-left: 45px;
	padding: 10px 24px;
	border: 1px outset rgb(121,121,121);
	border-bottom: none;
	border-top-left-radius: 5px;
	border-top-right-radius: 5px;
	background-color: rgb(121,121,121);
	color: white;
	font-size: 12px;
	text-transform: uppercase;
	text-align: center;
	cursor: pointer;
}

html > body.home > section > img,
html > body.home > section > h2 {
	display: inline-block;
	margin-top: 200px;
	vertical-align: top;
}

html > body.home > section > img {
	float: left;
	margin-left: 100px;
	max-width: 150px;
	max-height: 200px;
}

html > body.home > section > h2,
html > body.home > section > p {
	display: inline-block;
	width: 420px;
	margin-left: 20px;
	margin-bottom: 10px;
	color: rgb(103,103,103);
}

html > body.home > section > h2 {
	font-size: 40px;
	text-transform: capitalize;
}

html > body.home > section > p {
	font-size: 14px;
}

html > body.home > section > section#iframe {
	/* margin-top: 10px; */
	margin-top: 30px;
	padding: 5px;
	background-color: white;
	/*border-radius: 10px;
	border-top: 23px solid grey;
	border-bottom: 8px solid white;*/

	border-top-left-radius: 5px;
	border-top-right-radius: 5px;

	border-bottom-left-radius: 5px;
	border-bottom-right-radius: 5px;
	border-bottom: 5px solid white;
	border-left: 5px solid white;
	border-right: 5px solid white;
	overflow: auto;

	overflow: auto;
}

html > body.home > section > header {
	position: relative;
	/* Added */ margin-top: 25px;
	height: 25px;
	padding: 7px;
	background-color: rgb(227,227,228);
	border-top-left-radius: 5px;
	border-top-right-radius: 5px;
	border: 5px solid white;
	overflow: hidden;
	color: rgb(139,139,140);
	text-transform: uppercase;
}

html > body.home > section > header.full-height {
	height: 40px;
}

html > body.home > section > header > fieldset {
	position: relative;
	display: inline-block;
	height: 50px;
	overflow: hidden;
}

/* html > body.home > section > header > fieldset { */
.ui-dialog fieldset.toolbox {
	position: relative;
	/*display: inline-block;*/
	height: 50px;
	overflow: hidden;
}

/*html > body.home > section > header > fieldset > legend {*/
fieldset.toolbox > legend {
	/*position: absolute;
	top: 8px;
	left: 30px;*/
	display: none;
}

/* html > body.home > section > header > fieldset > label:not(:first-of-type) { */
fieldset.toolbox > label:not(:first-of-type) {
	/*margin-left: 90px;*/
	margin-left: 5px;
}

/*html > body.home > section > header > fieldset > label:not(:first-of-type) > span:first-of-type {*/
fieldset.toolbox > label:not(:first-of-type) > span:first-of-type {
	display: none;
}

/*html > body.home > section > header > fieldset > label:first-of-type > input[type="search"] {*/
fieldset.toolbox > label:first-of-type > input[type="search"] {
	width: calc(203px);
	height: 26px;
	padding-right: 28px;
	background-image: url('html/body.home/section/header/fieldset/label/input.png');
}

/*html > body.home > section > header > fieldset > label > input[type="checkbox"] {*/
fieldset.toolbox > label > input[type="checkbox"] {
	width: 20px;
	height: 20px;
	vertical-align: middle;
	margin-top: 5px;
}

