html > body.home > section > section#viewport section.sheet footer > article {
	/*
	width: calc(100% - 110px);
	margin: 20px auto;
	padding: 10px;
	background-color: rgb(247,247,248);
	border: 1px groove lightgrey;
	box-shadow: 2px -2px 2px grey;
	border-radius: 10px;
	color: black;
	*/
	
	/* width: calc(100% - 110px); */
	/* width: calc(100%); */
	width: calc(100% - 10px);
	/*margin: 20px auto;*/
	margin: 0 auto;
	/* padding: 10px; */
	padding: 10px 0 10px 10px;
	/* border: 1px groove lightgrey; */
	border-bottom: 1px solid rgb(240,240,240);
	color: black;

	background-color: rgb(247,247,248);
}


html > body.home > section > section#viewport section.sheet footer > article:nth-of-type(3n + 1) {
	background-color: rgb(237,237,238);
}


html > body.home > section > section#viewport section.sheet footer > article:nth-of-type(3n + 2) {
	background-color: rgb(242,242,243);
}


html > body.home > section > section#viewport section.sheet footer > article:nth-of-type(3n) {
	background-color: rgb(252,252,253);
}


html > body.home > section > section#viewport section.sheet footer > article:last-of-type {
	border-bottom: none;
}

html > body.home > section > section#viewport section.sheet footer > article > section {
	display: inline-block;
	width: calc(50% - 4px);
	margin-bottom: 15px;
	vertical-align: top;
}

html > body.home > section > section#viewport section.sheet footer > article > section.full-width {
	width: calc(100% - 4px);
}

html > body.home > section > section#viewport section.sheet footer > article > section.third-width {
	width: calc(100% / 3 - 4px);
}

html > body.home > section > section#viewport section.sheet footer > article > section > h1 {
	font-size: 13px;
	font-weight: bold;
	/* margin-top: 15px;
	margin-bottom: 10px; */
	margin: 15px 0 10px 0 !important;
	text-transform: none !important;
}

/* Begin sobrecargos */

html > body.home > section > section#viewport section.sheet footer > article > section > ul > li {
	margin-bottom: 5px;
}

html > body.home > section > section#viewport section.sheet footer > article > section > ul.summary > li,
html > body.home > section > section#viewport section.sheet footer > article > section > ul.summary > li > span {
	font-size: 14px !important;
}

html > body.home > section > section#viewport section.sheet footer > article > section > ul.summary > li > span:first-of-type {
	text-align: right;
	margin-right: 10px;
}

html > body.home > section > section#viewport section.sheet footer > article > section > ul > li input[type="number"] {
	text-align: right;
}

html > body.home > section > section#viewport section.sheet footer > article > section > ul > li > span:first-of-type {
	display: inline-block;
	/*width: calc(50% - 2px - 45px);*/
	width: calc(30% - 2px - 35px);
	font-weight: bold;
	text-transform: uppercase;
	font-size: 9px;
}

html > body.home > section > section#viewport section.sheet footer > article > section > ul > li > span:nth-of-type(2) {
	display: inline-block;
	width: calc(80px - 2px + 10px);
}

html > body.home > section > section#viewport section.sheet footer > article > section > ul.summary > li > span:nth-of-type(2) {
	width: calc(140px - 2px + 10px);
}

html > body.home > section > section#viewport section.sheet footer > article > section > ul > li > span:nth-of-type(2) > input {
	display: inline-block;
	width: calc(100% - 25px);
}

html > body.home > section > section#viewport section.sheet footer > article > section > ul > li > span.full-width {
	width: 50%;
}

html > body.home > section > section#viewport section.sheet footer > article > section > ul > li > span.percent {
	display: inline-block;
	width: calc(65px - 2px + 10px);
	text-align: right;
}

html > body.home > section > section#viewport section.sheet footer > article > section.sobrecargos > ul > li > span.percent {
	width: calc(85px - 2px + 10px);
}

html > body.home > section > section#viewport section.sheet footer > article > section > ul > li > span.percent > input {
	width: calc(100% - 25px);
}

html > body.home > section > section#viewport section.sheet footer > article > section > ul > li > span:last-of-type.percent > input {
	width: 40px !important;
}

html > body.home > section > section#viewport section.sheet footer > article > section > ul > li > span.currency {
	/*width: 70px;*/
	width: 90px;
}

html > body.home > section > section#viewport section.sheet footer > article > section > ul > li > span.currency > input {
	/*width: 50px;*/
	width: 65px;
}

html > body.home > section > section#viewport section.sheet footer > article > section > ul > li > span > textarea {
	/*width: 100%;*/
	width: 345%;
	height: 150px;
}

html > body.home > section > section#viewport section.sheet footer > article > section > ul > li > span.options {
	/* display: inline-block;
	width: calc(70px);
	text-align: right; */
}

html > body.home > section > section#viewport section.sheet footer > article > section > ul > li > span > input {
}

/* End sobrecargos */




/* Clases generales */
.left{text-align:left !important;}
.right{text-align:right !important;}
.center{text-align:center !important;}

.ui-dialog.alert *,
.ui-dialog.confirm *,
.ui-dialog.prompt * {
	font-size: 14px !important;

}

.ui-dialog > .ui-dialog-content > header {
	padding-top: 5px;
	padding-bottom: 5px;
	background-color: rgb(227,227,228);
}

.ui-dialog > .ui-dialog-content > fieldset {
	margin-top: 5px;
}

.ui-dialog > .ui-dialog-content > fieldset > legend {
	display: block;
	width: calc(100% - 10px);
	margin-bottom: 10px;
	padding: 10px 5px;
	font-size: 11px;
	font-weight: bold;
	background-color: rgb(245,242,242);
}

.ui-dialog > .ui-dialog-content > fieldset > label {
	display: block;
	margin-bottom: 5px;
}

.ui-dialog > .ui-dialog-content > fieldset > label > span:first-of-type {
	display: inline-block;
	width: calc(30% - 5px) !important;
}

.ui-dialog > .ui-dialog-content > fieldset > label > input[type="search"] {
	display: inline-block;
	width: calc(70% - 25px) !important;
}

.ui-dialog > .ui-dialog-content > fieldset > label > input[type="text"],
.ui-dialog > .ui-dialog-content > fieldset > label > input[type="file"] {
	display: inline-block;
	width: calc(70% - 15px) !important;
}

.ui-dialog > .ui-dialog-content > fieldset > label > button {
	width: 18px;
	height: 18px;
}

.ui-dialog fieldset {
	padding: 10px 5px;
	background-color: rgb(227,227,228);
}

.ui-dialog fieldset > legend {
	display: block;
	width: 100%;
	margin-left: -5px;
	padding: 5px;
	background-color: rgb(108,108,108);
	color: white;
	font-size: 11px;
	font-weight: bold;
}

#dialog-viewport fieldset > label {
	display: inline-block;
	width: calc(50% - 4px);
	margin-top: 5px;
	margin-bottom: 5px;

}

.ui-dialog fieldset > label > span:nth-of-type(1) {
	display: inline-block;
	width: calc(30% - 2px);
	font-weight: bold;
}

.ui-dialog fieldset > label > span:nth-of-type(2),
.ui-dialog fieldset > label > input {
	display: inline-block;
	width: calc(50% - 10px) !important;
}

.ui-dialog fieldset > label > span.numeric > input {
	text-align: right;
	width: calc(50% - 10px);
	padding-right: 0;
}

.ui-dialog fieldset > label > button {
	width: 16px;
	height: 16px;
}

.ui-dialog fieldset > label.full-width {
	width: calc(100% - 8px);
}

.ui-dialog fieldset > label.full-width > textarea {
	display: block;
	margin-top: 5px;
	width: 100%;
	height: 40px;
}

.ui-dialog fieldset > span {
	display: block;
	width: 100%;
	text-align: right;
}