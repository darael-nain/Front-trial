.dialog header {
	margin-top: 5px;
	margin-bottom: 5px;
}

#dialog-viewport {
	/* height: calc(100% - 100px); */
	height: calc(100% - 50px);
	overflow: auto;
}

header[style*="display: none"] + #dialog-viewport {
	height: calc(100%);
	overflow: auto;
}

/*.dialog > section > label {*/
#dialog-viewport > section > label {
	display: block;
	margin-top: 10px;
}

/*.dialog > section > label > input[type="checkbox"] {*/
#dialog-viewport > section > label > input[type="checkbox"] {
	width: auto !important;
	vertical-align: top;
}

nav#menu,
nav#dialog-menu {
	display: inline-block;
	width: auto;
	vertical-align: top;
}

nav#menu > ul,
nav#dialog-menu > ul {
	display: inline-block;
}

nav#menu > ul > li,
nav#dialog-menu > ul > li {
	display: inline-block;
	margin-left: 5px;
	margin-right: 5px;
}


/* TODO: Este estilo al parecer no se usa en ninguna parte, se debería verificar y eliminar si corresponde */
html > body.home > section > header > nav > ul > li > a {
	text-align: center;
}

/* TODO: Este estilo al parecer no se usa en ninguna parte, se debería verificar y eliminar si corresponde */
html > body.home > section > header > nav > ul > li > a > div {
	display: block;
	width: 38px;
	height: 38px;
	margin: 0 auto;
	background-image: url('html/body.home/section/header/nav/ul/li/a.png');
	background-repeat: repeat-x;
	opacity: .5;
	transition: opacity .5s ease-in-out;
}

/* TODO: Este estilo al parecer no se usa en ninguna parte, se debería verificar y eliminar si corresponde */
html > body.home > section > header > nav > ul > li:hover > a > div {
	opacity: 1;
}

/* TODO: Este estilo al parecer no se usa en ninguna parte, se debería verificar y eliminar si corresponde */
html > body.home > section > header > nav > ul > li.add > a > div {
	background-position-x: calc((38px * 1) - 38px);
}

/* TODO: Este estilo al parecer no se usa en ninguna parte, se debería verificar y eliminar si corresponde */
html > body.home > section > header > nav > ul > li.export > a > div {
	background-position-x: calc((38px * 2) - 38px);
}

/* TODO: Este estilo al parecer no se usa en ninguna parte, se debería verificar y eliminar si corresponde */
html > body.home > section > header > nav > ul > li.print > a > div {
	background-position-x: calc((38px * 3) - 38px);
}

/* TODO: Este estilo al parecer no se usa en ninguna parte, se debería verificar y eliminar si corresponde */
html > body.home > section > header > nav > ul > li.delete > a > div {
	background-position-x: calc((38px * 4) - 38px);
}

/* TODO: Este estilo al parecer no se usa en ninguna parte, se debería verificar y eliminar si corresponde */
html > body.home > section > header > nav > ul > li > a > span {
	display: block;
	font-size: 8px;
	text-align: center;
}

html > body.home > section > section#viewport {
	padding: 0;
	background-color: white;
	border-bottom-left-radius: 5px;
	border-bottom-right-radius: 5px;
	border-bottom: 5px solid white;
	border-left: 5px solid white;
	border-right: 5px solid white;
	overflow: auto;
}

html > body.home > section > section#viewport.standalone {
	margin-top: 5px;
	padding: 0;
	background-color: transparent;
	border: none;
	overflow: auto;
}

html > body.home > section > section#viewport > section {
	min-width: 1130px;
}

html > body.home > section > section#viewport > h1 {

}

html > body.home > section > section#viewport > section#tabs > ul > li a {
	background-color: rgb(198,198,200);
	color: white;
	font-size: 12px;
}

html > body.home > section > section#viewport > section#tabs > ul li.active a {
	background-color: rgb(165,165,167);
}

html > body.home > section > section#viewport > section#tabs > ul > li a:not(.previous-tab):not(.next-tab) {
	margin-right: 1px;
}

html > body.home > section > section#viewport > section#tabs > article {
	padding: 15px;
	background-color: rgb(165,165,167);
	color: white;
}

html > body.home > section > section#viewport > section#tabs > article > h1 {
	margin-bottom: -30px;
	font-size: 14px;
	font-weight: bold;
	text-transform: uppercase;
}

html > body.home > section > section#viewport > section#tabs > article > fieldset {
	display: inline-block;
	width: calc(50% - 2px - 7px * 2 - 15px * 2);
	margin-bottom: 10px;
	padding: 0 15px 15px 15px;
	background-color: rgb(227,227,228);
	border-radius: 10px;
	text-align: right;
}

html > body.home > section > section#viewport > section#tabs > article > fieldset:nth-of-type(2n+1) {
	margin-right: 7px;
}

html > body.home > section > section#viewport > section#tabs > article > fieldset:nth-of-type(2n) {
	margin-left: 7px;
}

html > body.home > section > section#viewport > section#tabs > article > fieldset > legend {
	display: block;
	padding-top: 70px;
	padding-bottom: 20px;
	color: rgb(121,121,121);
	text-transform: uppercase;
	font-size: 14px;
	font-weight: bold;
	text-align: left;
}

html > body.home > section > section#viewport > section#tabs > article > fieldset > label {
	display: block;
	margin-bottom: 10px;
	text-align: right;
}

html > body.home > section > section#viewport > section#tabs > article > fieldset > label > span {
	display: inline-block;
	width: calc(30% - 2px - 10px);
	margin-right: 1`0px;
	font-size: 11px;
	text-transform: uppercase;
}

html > body.home > section > section#viewport > section#tabs > article > fieldset > label > input,
html > body.home > section > section#viewport > section#tabs > article > fieldset > label > select {
	display: inline-block;
	width: calc(70% - 2px);
	height: 23px;
	background-color: white;
	border: 1px solid rgb(214,214,215);
	border-radius: 5px;
}

html > body.home > section > section#viewport > section#tabs > article > fieldset > label > span {
	color: rgb(121,121,121);
	text-transform: uppercase;
}

html > body.home > section > section#viewport > section#tabs > article > fieldset > button {
	display: inline-block;
}

html > body.home > section > section#viewport section.sheet {
	min-height: calc(100vh - 220px);
}

html > body.home > section > section#viewport section.sheet > header {
	position: relative;
	height: 40px;
	background-color: rgb(245,242,242);
}

html > body.home > section > section#viewport section.sheet > header > h1 > img {
	width: 100px;
}

html > body.home > section > section#viewport section.sheet > header > span,
html > body.home > section > section#viewport section.sheet > header > time,
html > body.home > section > section#viewport section.sheet > header > ul {
	position: absolute;
}

html > body.home > section > section#viewport section.sheet > header > span:first-of-type {
	right: 5px;
	top: 5px;
	font-size: 14px;
	font-weight: bold;
}

html > body.home > section > section#viewport section.sheet > header > time {
	right: 5px;
	top: 20px;
}

html > body.home > section > section#viewport section.sheet > header > ul {
	left: 5px;
	top: 8px;
	font-size: 11px;
}

html > body.home > section > section#viewport section.sheet > header > ul > li {
	display: block;
}

html > body.home > section > section#viewport section.sheet > header > ul > li > strong {
	font-weight: bold;
}


html > body.home > section > section#viewport section.sheet > header > ul > li > strong:after {
	content: ':';
}

